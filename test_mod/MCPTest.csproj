<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <RootNamespace>MCPTest</RootNamespace>
    <AssemblyName>MCPTest</AssemblyName>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Set STS2_GAME_DIR env var or pass /p:Sts2GameDir=... to override -->
    <Sts2GameDir Condition="'$(Sts2GameDir)' == ''">$(STS2_GAME_DIR)</Sts2GameDir>
    <!-- Platform-specific data subfolder names -->
    <Sts2DataDir Condition="$([MSBuild]::IsOSPlatform('Windows'))">data_sts2_windows_x86_64</Sts2DataDir>
    <Sts2DataDir Condition="$([MSBuild]::IsOSPlatform('Linux')) And Exists('$(Sts2GameDir)/data_sts2_linuxbsd_x86_64')">data_sts2_linuxbsd_x86_64</Sts2DataDir>
    <Sts2DataDir Condition="$([MSBuild]::IsOSPlatform('Linux')) And '$(Sts2DataDir)' == ''">data_sts2_linux_x86_64</Sts2DataDir>
    <Sts2DataDir Condition="$([MSBuild]::IsOSPlatform('OSX'))">SlayTheSpire2.app/Contents/Resources/data_sts2_macos_arm64</Sts2DataDir>
    <Sts2Dir>$(Sts2GameDir)/$(Sts2DataDir)</Sts2Dir>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="GodotSharp" Version="4.4.0" />
    <PackageReference Include="Lib.Harmony" Version="2.4.2" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="sts2">
      <HintPath>$(Sts2Dir)/sts2.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
</Project>
